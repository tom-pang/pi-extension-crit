{
  "name": "pi-extension-diffs",
  "version": "0.1.0",
  "description": "Pi extension — /diffs command to view git changes in a native window",
  "type": "module",
  "scripts": {
    "build": "bun build src/viewer.tsx --bundle --minify --outfile dist/viewer.js --define 'process.env.NODE_ENV=\"production\"'"
  },
  "dependencies": {
    "@pierre/diffs": "^1.0.11",
    "glimpseui": "^0.3.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HazAT/pi-extension-diffs.git"
  },
  "keywords": [
    "pi",
    "extension",
    "git",
    "diffs",
    "macos"
  ]
}
